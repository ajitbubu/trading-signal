# Copy to .env and fill in. Never commit .env.

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501

# --- Logging ---
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=sqlite:///data/app.db

# --- News provider API keys (free tiers, optional but recommended) ---
FINNHUB_API_KEY=
MARKETAUX_API_KEY=
GNEWS_API_KEY=
ALPHAVANTAGE_API_KEY=

# --- LLM feature flag ---
ENABLE_AI_SUMMARIES=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Briefing email (Gmail App Password recommended) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BRIEFING_EMAIL_FROM=
BRIEFING_EMAIL_TO=
BRIEFING_COMBINE=false

# --- Refresh intervals (seconds) ---
PRICE_REFRESH_SECONDS=60
NEWS_REFRESH_SECONDS=300

# --- Rate limit knobs ---
YFINANCE_CONCURRENCY=8
PROVIDER_MAX_RETRIES=3
